# CausalForge Backend Environment Variables
# Copy this file to .env and fill in your values

# NVIDIA NIM API key for LLM inference and embeddings
# Get yours at: https://build.nvidia.com/
NIM_API_KEY=nvapi-your-key-here

# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/causalforge?retryWrites=true&w=majority

# MongoDB database name
MONGODB_DB=causalforge
